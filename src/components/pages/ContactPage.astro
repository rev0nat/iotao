---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getDictionary } from "../../i18n";

interface Props {
    lang: "fr" | "en";
}

const { lang } = Astro.props;

const t = getDictionary(lang);
---

<BaseLayout lang={lang}>
    <section class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12">
        <!-- LEFT: FORM -->
        <div class="bg-white rounded-2xl p-8 shadow-sm bg-zinc-50">
            <h2 class="text-2xl font-semibold mb-2">Contact</h2>
            <p class="text-sm text-zinc-600 mb-6">
            Une question ? Une prise de rendez-vous ? Je vous réponds rapidement.
            </p>

            <form class="flex flex-col gap-4">
                <input
                    type="text"
                    placeholder="Nom"
                    class="w-full px-4 py-3 rounded-lg border border-zinc-200 focus:outline-none focus:ring-2 focus:ring-[#ffc47d]"
                />
                <input
                    type="email"
                    placeholder="Email"
                    class="w-full px-4 py-3 rounded-lg border border-zinc-200 focus:outline-none focus:ring-2 focus:ring-[#ffc47d]"
                />
                <input
                    type="text"
                    placeholder="Sujet"
                    class="w-full px-4 py-3 rounded-lg border border-zinc-200 focus:outline-none focus:ring-2 focus:ring-[#ffc47d]"
                />
                <textarea
                    rows="5"
                    placeholder="Votre message"
                    class="w-full px-4 py-3 rounded-lg border border-zinc-200 focus:outline-none focus:ring-2 focus:ring-[#ffc47d]"
                ></textarea>
                <button
                    type="submit"
                    class="mt-2 bg-[#ffc001] text-white font-medium py-3 rounded-lg hover:bg-[#ff9933] transition"
                >
                    Envoyer
                </button>
                <p class="text-xs text-zinc-500 mt-2">
                    Vos données restent confidentielles.
                </p>
            </form>
        </div>

        <!-- RIGHT: MAP + INFO -->
        <div class="flex flex-col gap-6">

            <div class="bg-zinc-50 rounded-2xl overflow-hidden shadow-sm">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d986739.7841425833!2d-0.3383914185751206!3d43.143824359243496!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12a9a9cce9505757%3A0x8cd734e26416c2d8!2s2%20Chem.%20des%20Goutilles%2C%2065230%20Betb%C3%A8ze%2C%20France!5e0!3m2!1sfr!2ses!4v1782506812410!5m2!1sfr!2ses"
                    width="100%"
                    height="320"
                    style="border:0;"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>
                </div>

                <div class="bg-zinc-50 rounded-2xl p-6 shadow-sm">
                <h3 class="font-semibold mb-2">Où me trouver</h3>
                <p class="text-sm text-zinc-600">
                    Betbèze (65), Hautes-Pyrénées<br />
                    Consultations sur rendez-vous
                </p>

                <div class="mt-4 text-sm">
                    <p class="font-medium">Horaires</p>
                    <p class="text-zinc-600">Lun - Sam : 9h - 18h</p>
                </div>
            </div>

        </div>

        </section>
</BaseLayout>