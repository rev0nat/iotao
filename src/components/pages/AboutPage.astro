---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getDictionary } from "../../i18n";

interface Props {
    lang: "fr" | "en";
}

const { lang } = Astro.props;

const t = getDictionary(lang);
---

<BaseLayout lang={lang}>
    <main class="text-zinc-900">

    <!-- HERO -->
    <section class="section-main section-paw-mark">
        <p class="text-sm tracking-widest uppercase text-zinc-500">
        {t.about.hero.eyebrow}
        </p>

        <h1 class="mt-6 text-5xl md:text-6xl font-light tracking-tight leading-tight">
        <span class="font-normal text-zinc-700">{t.about.hero.title}</span><br />
        <span class="font-normal text-zinc-700">{t.about.hero.subtitle}</span>
        </h1>

        <p class="mt-6 max-w-2xl mx-auto text-lg text-zinc-600">
        {t.about.hero.description}
        </p>
    </section>

    <!-- PRESENTATION -->
    <section class="py-24 bg-white border-y border-zinc-100">
        <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">

        <!-- Photo -->
        <div class="flex justify-center">
            <img
            src={"/public/images/frede.png"}
            alt="Portrait de l'ostéopathe"
            class="w-full max-w-md rounded-3xl object-cover shadow-lg"
            />
        </div>

        <!-- Text -->
        <div>

            <p class="text-sm tracking-widest uppercase text-zinc-500 mb-4">
            {t.about.presentation.eyebrow}
            </p>

            <h2 class="text-4xl font-light tracking-tight">
            {t.about.presentation.title}
            </h2>

            <div class="mt-8 space-y-6 text-zinc-600 leading-8">

            <p>
                {t.about.presentation.paragraphs[0]}
            </p>

            <p>
                {t.about.presentation.paragraphs[1]}
            </p>

            <p>       
                {t.about.presentation.paragraphs[2]}
            </p>

                {t.about.presentation.paragraphs[3]}
            </p>

            <p>       
                {t.about.presentation.paragraphs[4]}
            </p>

            </div>

        </div>

        </div>
    </section>

    <!-- VALUES -->
    <section class="section-main section-paw-mark">
        <p class="text-sm tracking-widest uppercase text-zinc-500">
        {t.about.expertise.eyebrow}
        </p>
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-10 mt-6">
            {t.about.expertise.cards.map((card) => (
                <div class="cards-main">
                <h3 class="text-2xl font-medium text-left">
                    {card.title}
                </h3>

                <div class="mt-6 space-y-2 text-sm text-zinc-600 text-left">
                    {card.description.map((line) => (
                    <p>• {line}</p>
                    ))}
                </div>
                </div>
            ))}
        </div>
    </section>

    <!-- QUOTE -->
    <section class="section-main-white">
        <div class="max-w-3xl mx-auto px-6 text-center">

        <blockquote class="text-3xl font-light italic leading-relaxed text-zinc-800">
            {t.about.quote}
        </blockquote>

        </div>
    </section>

    </main>
</BaseLayout>