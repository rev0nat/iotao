---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getDictionary } from "../../i18n";

interface Props {
    lang: "fr" | "en";
}

const { lang } = Astro.props;

const t = getDictionary(lang);
---

<BaseLayout lang={lang}>
    <main class="text-zinc-900">

    <!-- HERO -->
    <section class="section-main">
        <p class="text-sm tracking-widest uppercase text-zinc-500">
        À propos
        </p>

        <h1 class="mt-6 text-5xl md:text-6xl font-light tracking-tight leading-tight">
        Une expertise au service du vivant.<br />
        <span class="font-normal text-zinc-700">
            Dr Vet. Frédérique CLUSEL
        </span>
        </h1>

        <p class="mt-6 max-w-2xl mx-auto text-lg text-zinc-600">
        Derrière chaque consultation se trouve une conviction : comprendre
        l'animal dans sa globalité afin de lui apporter un accompagnement précis,
        respectueux et personnalisé.
        </p>
    </section>

    <!-- PRESENTATION -->
    <section class="py-24 bg-white border-y border-zinc-100">
        <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">

        <!-- Photo -->
        <div class="flex justify-center">
            <img
            src={"/public/images/frede.png"}
            alt="Portrait de l'ostéopathe"
            class="w-full max-w-md rounded-3xl object-cover shadow-lg"
            />
        </div>

        <!-- Text -->
        <div>

            <p class="text-sm tracking-widest uppercase text-zinc-500 mb-4">
            Mon parcours
            </p>

            <h2 class="text-4xl font-light tracking-tight">
            Une passion pour la santé animale.
            </h2>

            <div class="mt-8 space-y-6 text-zinc-600 leading-8">

            <p>
                Passionnée du règne animal et amoureuse du monde vivant, 
                Frédérique devient vétérinaire et se spécialise en médecine aviaire. 
            </p>

            <p>
                Après quatre années en clinique vétérinaire, elle rejoint l’univers de la santé et nutrition animale, 
                découvre le monde et ses cultures en voyageant professionnellement et en famille.
                Trente ans d’expérience affinent son leadership, forgent ses compétences et aiguisent son sens des affaires.
            </p>

            <p>       
                Pour revenir à une pratique raisonnée de la médecine vétérinaire, 
                elle se forme en médecine manuelle vétérinaire (« ostéopathie vétérinaire »).
                Aujourd’hui, Frédérique consulte et soigne, animaux et entreprises.
            </p>

            </div>

        </div>

        </div>
    </section>

    <!-- VALUES -->
    <section class="section-main py-20">
        <p class="text-sm tracking-widest uppercase text-zinc-500">
        Expertise
        </p>
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-10 mt-6">

            <div class="cards-main">
            <h3 class="text-lg font-medium">
                Formation
            </h3>

            <p class="mt-3 text-sm text-zinc-600">
                Docteur vétérinaire, Executive MBA et diplômé en ostéopathie vétérinaire.
            </p>
            </div>

            <div class="cards-main">
            <h3 class="text-lg font-medium">
                Lesaffre (2013–2023)
            </h3>

            <p class="mt-3 text-sm text-zinc-600">
                Membre du Comité Exécutif et dirigeant international. Pilotage de trois
                divisions à l'échelle mondiale, croissance à deux chiffres, montée en
                gamme des activités, lancement de plus de cinq innovations majeures et
                renforcement de la stratégie RSE.
            </p>
            </div>

            <div class="cards-main">
            <h3 class="text-lg font-medium">
                Zoetis (2009–2013)
            </h3>

            <p class="mt-3 text-sm text-zinc-600">
                Directeur Groupe EAME et responsable Business Development. Relance de
                l'activité avec un passage d'une décroissance de 5&nbsp;% à une croissance
                de 12&nbsp;%.
            </p>
            </div>

            <div class="cards-main">
            <h3 class="text-lg font-medium">
                MSD (2003–2009)
            </h3>

            <p class="mt-3 text-sm text-zinc-600">
                Directeur de Business Unit en France puis en Malaisie. Doublement du
                chiffre d'affaires à la suite de la fusion des activités.
            </p>
            </div>

            <div class="cards-main">
            <h3 class="text-lg font-medium">
                Ceva & Vétoquinol
            </h3>

            <p class="mt-3 text-sm text-zinc-600">
                Fonctions en marketing et affaires réglementaires en Europe et en Asie
                du Sud-Est, au service du développement de la santé animale.
            </p>
            </div>

            <div class="cards-main">
            <h3 class="text-lg font-medium">
                Pratique vétérinaire
            </h3>

            <p class="mt-3 text-sm text-zinc-600">
                Exercice en médecine des animaux de compagnie et des oiseaux, complété
                par une expertise en ostéopathie vétérinaire.
            </p>
            </div>

        </div>
        </section>

    <!-- QUOTE -->
    <section class="pb-24">
        <div class="max-w-3xl mx-auto px-6 text-center">

        <blockquote class="text-3xl font-light italic leading-relaxed text-zinc-800">
            « Chaque animal mérite une attention particulière.
            Mon rôle est de l'accompagner vers un meilleur équilibre avec douceur,
            précision et respect. »
        </blockquote>

        </div>
    </section>

    </main>
</BaseLayout>