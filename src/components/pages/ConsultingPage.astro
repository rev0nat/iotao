---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getDictionary } from "../../i18n";

interface Props {
    lang: "fr" | "en";
}

const { lang } = Astro.props;

const t = getDictionary(lang);
---

<BaseLayout lang={lang} title={t.consulting.seo.title} description={t.consulting.seo.description}>
    <main class="text-zinc-900">

    <!-- HERO -->
    <section class="section-main section-paw-mark">
        <p class="text-sm tracking-widest uppercase text-zinc-500">
        {t.consulting.hero.eyebrow}
        </p>

        <h1 class="mt-6 text-5xl md:text-6xl font-light tracking-tight leading-tight">
        <span class="font-normal text-zinc-700">{t.consulting.hero.title}</span><br />
        <span class="font-normal text-zinc-700">{t.consulting.hero.subtitle}</span>
        </h1>

        <p class="mt-6 max-w-2xl mx-auto text-lg text-zinc-600">
        {t.consulting.hero.description}
        </p>
    </section>

    <!-- PRESENTATION -->
    <section class="section-main-white-text-left">
        <div class="max-w-4xl mx-auto px-6 text-center">

            <p class="text-sm tracking-widest uppercase text-zinc-500">
            {t.consulting.method.eyebrow}
            </p>

            <h2 class="mt-4 text-4xl font-light tracking-tight">
            {t.consulting.method.title}
            </h2>

            <div class="mt-8 max-w-3xl mx-auto text-lg text-zinc-600 leading-8">

            <p>
                {t.consulting.method.description}
            </p>

            </div>

            <div class="mt-16">
            <h3 class="text-2xl font-light text-zinc-900">
                {t.consulting.method.collaborationTitle}
            </h3>
            <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto leading-8">
                {t.consulting.method.collaborationDescription}
            </p>
            </div>

        </div>
        </section>

    <!-- DOMAINES D'INTERVENTION -->
    <section class="section-main-text-left section-paw-mark">
        <div class="max-w-6xl mx-auto px-6 grid gap-8 md:grid-cols-2">

            <!-- Card -->
            <div class="cards-main">
            <h3 class="text-2xl font-medium">
                {t.consulting.domains.cards[0].title}
            </h3>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
                <p>{t.consulting.domains.cards[0].items[0]}</p>
                <p>{t.consulting.domains.cards[0].items[1]}</p>
                <p>{t.consulting.domains.cards[0].items[2]}</p>
            </div>
            </div>

            <!-- Card -->
            <div class="cards-main">
            <h3 class="text-2xl font-medium">
                {t.consulting.domains.cards[1].title}
            </h3>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
                <p>{t.consulting.domains.cards[1].items[0]}</p>
                <p>{t.consulting.domains.cards[1].items[1]}</p>
                <p>{t.consulting.domains.cards[1].items[2]}</p>
                <p>{t.consulting.domains.cards[1].items[3]}</p>
            </div>
            </div>

            <!-- Card -->
            <div class="cards-main">
            <h3 class="text-2xl font-medium">
                {t.consulting.domains.cards[2].title}
            </h3>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
                <p>{t.consulting.domains.cards[2].items[0]}</p>
                <p>{t.consulting.domains.cards[2].items[1]}</p>
                <p>{t.consulting.domains.cards[2].items[2]}</p>
                <p>{t.consulting.domains.cards[2].items[3]}</p>
                <p>{t.consulting.domains.cards[2].items[4]}</p>
            </div>
            </div>

            <!-- Card -->
            <div class="cards-main">
            <h3 class="text-2xl font-medium">
                {t.consulting.domains.cards[3].title}
            </h3>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
                <p>{t.consulting.domains.cards[3].items[0]}</p>
                <p>{t.consulting.domains.cards[3].items[1]}</p>
                <p>{t.consulting.domains.cards[3].items[2]}</p>
            </div>
            </div>

        </div>
    </section>
    

    <!-- DETAILS PRESTATIONS -->
    <section class="section-main-white-text-left">
        <div class="max-w-6xl mx-auto px-6 grid gap-8 md:grid-cols-2">

        <!-- Card -->
        <div class="cards-main">
            <div class="flex justify-between items-start gap-6">
            <h3 class="text-2xl font-medium">
                {t.consulting.services.cards[0].title}
            </h3>

            <span class="text-2xl font-light whitespace-nowrap">
                {t.consulting.services.cards[0].price}
            </span>
            </div>

            <p class="mt-4 text-zinc-600">
            {t.consulting.services.cards[0].description}
            </p>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
            <p>{t.consulting.services.cards[0].items[0]}</p>
            <p>{t.consulting.services.cards[0].items[1]}</p>
            <p>{t.consulting.services.cards[0].items[2]}</p>
            </div>
        </div>

        <!-- Card -->
        <div class="cards-main">
            <div class="flex justify-between items-start gap-6">
            <h3 class="text-2xl font-medium">
                {t.consulting.services.cards[1].title}
            </h3>

            <span class="text-2xl font-light whitespace-nowrap">
                {t.consulting.services.cards[1].price}
            </span>
            </div>

            <p class="mt-4 text-zinc-600">
            {t.consulting.services.cards[1].description}
            </p>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
            <p>{t.consulting.services.cards[1].items[0]}</p>
            <p>{t.consulting.services.cards[1].items[1]}</p>
            <p>{t.consulting.services.cards[1].items[2]}</p>
            </div>
        </div>

        <!-- Card -->
        <div class="cards-main">
            <div class="flex justify-between items-start gap-6">
            <h3 class="text-2xl font-medium">
                {t.consulting.services.cards[2].title}
            </h3>

            <span class="text-2xl font-light whitespace-nowrap">
                {t.consulting.services.cards[2].price}
            </span>
            </div>

            <p class="mt-4 text-zinc-600">
            {t.consulting.services.cards[2].description}
            </p>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
            <p>{t.consulting.services.cards[2].items[0]}</p>
            <p>{t.consulting.services.cards[2].items[1]}</p>
            <p>{t.consulting.services.cards[2].items[2]}</p>
            </div>
        </div>

        <!-- Card -->
        <div class="cards-main">
            <div class="flex justify-between items-start gap-6">
            <h3 class="text-2xl font-medium">
                {t.consulting.services.cards[3].title}
            </h3>

            <span class="text-2xl font-light whitespace-nowrap">
                {t.consulting.services.cards[3].price}
            </span>
            </div>

            <p class="mt-4 text-zinc-600">
            {t.consulting.services.cards[3].description}
            </p>

            <div class="mt-6 space-y-2 text-sm text-zinc-600">
            <p>{t.consulting.services.cards[3].items[0]}</p>
            <p>{t.consulting.services.cards[3].items[1]}</p>
            <p>{t.consulting.services.cards[3].items[2]}</p>
            </div>
        </div>

        </div>
    </section>

    <!-- CTA -->
    <section class="section-main section-paw-mark">
        <div class="max-w-3xl mx-auto px-6 text-center">

        <h2 class="text-4xl font-light">
            {t.consulting.cta.title}
        </h2>

        <p class="mt-4 text-lg text-zinc-600">
            {t.consulting.cta.description}
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">

            <a
            href="mailto:contact@votresite.fr"
            class="px-6 py-3 rounded-full border border-zinc-300 hover:border-zinc-900 transition"
            >
            {t.consulting.cta.secondaryButton}
            </a>

        </div>

        </div>
    </section>

    </main>
</BaseLayout>