---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getDictionary } from "../../i18n";

interface Props {
    lang: "fr" | "en";
}

const { lang } = Astro.props;

const t = getDictionary(lang);
---

<BaseLayout lang={lang} title={t.consultations.seo.title} description={t.consultations.seo.description}>


<main class="text-zinc-900">

  <!-- HERO -->
  <section class="section-main section-paw-mark">
    <p class="text-sm tracking-widest uppercase text-zinc-500">
      {t.consultations.hero.eyebrow}
    </p>

    <h1 class="mt-6 text-5xl md:text-6xl font-light tracking-tight leading-tight">
      <span class="font-normal text-zinc-700">{t.consultations.hero.title}<br /></span>
      <span class="font-normal text-zinc-700">{t.consultations.hero.subtitle}</span>
    </h1>

    <p class="mt-6 max-w-2xl mx-auto text-lg text-zinc-600">
      {t.consultations.hero.description}
    </p>
  </section>

  <section class="section-main-white-text-left">
    <div class="max-w-6xl mx-auto px-6 grid gap-8 md:grid-cols-2">

      <!-- Service -->
      <div class="cards-main">
        <div class="flex justify-between items-start gap-6">
          <h2 class="text-2xl font-medium">
            {t.consultations.overview.cards[0].title}
          </h2>
        </div>

        <div class="mt-6 space-y-2 text-sm text-zinc-600">
          <p>{t.consultations.overview.cards[0].items[0]}</p>
          <p>{t.consultations.overview.cards[0].items[1]}</p>
          <p>{t.consultations.overview.cards[0].items[2]}</p>
          <p>{t.consultations.overview.cards[0].items[3]}</p>
          <p>{t.consultations.overview.cards[0].items[4]}</p>
        </div>
      </div>

      <!-- Service -->
      <div class="cards-main">
        <div class="flex justify-between items-start gap-6">
          <h2 class="text-2xl font-medium">
            {t.consultations.overview.cards[1].title}
          </h2>
        </div>

        <div class="mt-6 space-y-2 text-sm text-zinc-600">
          <p>{t.consultations.overview.cards[1].items[0]}</p>
          <p>{t.consultations.overview.cards[1].items[1]}</p>
          <p>{t.consultations.overview.cards[1].items[2]}</p>
          <p>{t.consultations.overview.cards[1].items[3]}</p>
          <p>{t.consultations.overview.cards[1].items[4]}</p>
          <p>{t.consultations.overview.cards[1].items[5]}</p>
          <p>{t.consultations.overview.cards[1].items[6]}</p>
        </div>
      </div>

      <!-- Service -->
      <div class="cards-main">
        <div class="flex justify-between items-start gap-6">
          <h2 class="text-2xl font-medium">
            {t.consultations.overview.cards[2].title}
          </h2>
        </div>

        <div class="mt-6 space-y-2 text-sm text-zinc-600">
          <p>{t.consultations.overview.cards[2].items[0]}</p>
          <p>{t.consultations.overview.cards[2].items[1]}</p>
          <p>{t.consultations.overview.cards[2].items[2]}</p>
          <p>{t.consultations.overview.cards[2].items[3]}</p>
          <p>{t.consultations.overview.cards[2].items[4]}</p>
          <p>{t.consultations.overview.cards[2].items[5]}</p>
        </div>
      </div>

      <!-- Service -->
      <div class="cards-main">
        <div class="flex justify-between items-start gap-6">
          <h2 class="text-2xl font-medium">
            {t.consultations.overview.cards[3].title}
          </h2>
        </div>

        <p class="mt-4 text-zinc-600 text-sm">
          {t.consultations.overview.cards[3].description}
        </p>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="section-main">
    <div class="max-w-3xl mx-auto text-center px-6">
      <h2 class="text-4xl font-light">
        {t.consultations.cta.title}
      </h2>

      <p class="mt-4 text-zinc-600">
        {t.consultations.cta.description}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/contact"
          class="px-6 py-3 rounded-full colors-cta shadow-sm transition"
        >
          {t.consultations.cta.button}
        </a>

        <a
          href="tel:+33XXXXXXXXX"
          class="px-6 py-3 rounded-full border border-zinc-300 hover:border-zinc-900 transition"
        >
          {t.consultations.cta.call}
        </a>
      </div>
    </div>
  </section>

</main>

</BaseLayout>