---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout>

    <!-- HERO -->
    <section class="section-main">
      <h1 class="mt-6 text-5xl md:text-6xl font-light leading-tight tracking-tight">
        La précision du geste.<br />
        <span class="font-normal text-zinc-700">La justesse du regard.</span>
      </h1>

      <p class="mt-6 text-lg text-zinc-600 max-w-2xl">
        Médecine manuelle vétérinaire · Conseil en santé animale
      </p>

      <p class="mt-6 text-lg text-zinc-600 max-w-2xl">
        J'accompagne les animaux, leurs propriétaires et les entreprises de la santé animale avec une même exigence : observer, comprendre et agir avec précision.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href="/contact"
           class="px-6 py-3 rounded-full colors-cta transition shadow-sm">
          Me contacter
        </a>

        <a href="tel:+33XXXXXXXXX"
           class="px-6 py-3 rounded-full border border-zinc-300 hover:border-zinc-900 transition">
          Appeler
        </a>
      </div>
    </section>

    <!-- APPROCHE -->
    <section class="py-20 bg-white border-y border-zinc-100">
      <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-10 text-center">

        <div class="cards-main">
          <h3 class="font-medium text-lg">Approche globale</h3>
          <p class="mt-2 text-zinc-600 text-sm">
            Observation complète pour comprendre les interactions avant d'agir.
          </p>
        </div>

        <div class="cards-main">
          <h3 class="font-medium text-lg">Expertise vétérinaire</h3>
          <p class="mt-2 text-zinc-600 text-sm">
            Plus de 30 ans d'expérience clinique et internationale en santé animale.
          </p>
        </div>

        <div class="cards-main">
          <h3 class="font-medium text-lg">Soins précis</h3>
          <p class="mt-2 text-zinc-600 text-sm">
            Techniques adaptées, précises et respectueuses du vivant.
          </p>
        </div>

      </div>
    </section>

    <!-- POURQUOI IOTAO -->
    <section class="py-24 max-w-6xl mx-auto px-6">
      <h2 class="text-center text-3xl font-light mb-12">
        Pourquoi iotao ?
      </h2>

      <p class="text-center text-zinc-600 max-w-2xl mx-auto mb-12">
        Le nom iotao est né de la rencontre de deux idées qui reflètent ma manière d'exercer mon métier.
      </p>

      <div class="grid md:grid-cols-2 gap-8">

        <div class="bg-white p-8 rounded-2xl border border-zinc-100">
          <h3 class="font-medium text-lg mb-3">Iota</h3>
          <p class="text-sm text-zinc-600">
            Évoque l'attention portée au détail, à ce qui est presque invisible. Un infime détail peut parfois faire toute la différence.
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl border border-zinc-100">
          <h3 class="font-medium text-lg mb-3">Tao</h3>
          <p class="text-sm text-zinc-600">
            Évoque la recherche du mouvement juste, de l'équilibre et de l'harmonie dans l'observation, la précision et le respect du vivant.
          </p>
        </div>

      </div>
    </section>

    <!-- DEUX EXPERTISES -->
    <section class="py-24 bg-white border-y border-zinc-100">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-center text-3xl font-light mb-12">
          Deux expertises, une même approche
        </h2>

        <div class="grid md:grid-cols-2 gap-8">

          <div class="bg-zinc-50 p-8 rounded-2xl">
            <h3 class="font-medium text-lg mb-4">Médecine manuelle vétérinaire</h3>
            <p class="text-sm text-zinc-600 mb-4">
              Une approche complémentaire qui vise à restaurer la mobilité, améliorer le confort et accompagner la santé de l'animal dans le respect de sa physiologie.
            </p>
            <a href="/consultations" class="text-zinc-900 underline hover:no-underline text-sm">
              Découvrir les consultations →
            </a>
          </div>

          <div class="bg-zinc-50 p-8 rounded-2xl">
            <h3 class="font-medium text-lg mb-4">Conseil en santé animale</h3>
            <p class="text-sm text-zinc-600 mb-4">
              J'accompagne les entreprises dans leurs projets d'innovation, de développement, de nutrition, de santé animale et de transformation stratégique.
            </p>
            <a href="/conseil" class="text-zinc-900 underline hover:no-underline text-sm">
              Découvrir le conseil →
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section class="py-24 max-w-6xl mx-auto px-6">
      <h2 class="text-center text-3xl font-light mb-12">
        Une expérience au service du vivant
      </h2>

      <div class="max-w-3xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">

          <div class="bg-white p-8 rounded-2xl border border-zinc-100">
            <h3 class="font-medium text-base mb-3">Docteur vétérinaire</h3>
            <p class="text-sm text-zinc-600">
              Formation complète en médecine vétérinaire et en ostéopathie vétérinaire.
            </p>
          </div>

          <div class="bg-white p-8 rounded-2xl border border-zinc-100">
            <h3 class="font-medium text-base mb-3">Expertise internationale</h3>
            <p class="text-sm text-zinc-600">
              Plus de 30 ans d'expérience en santé animale, nutrition et développement stratégique.
            </p>
          </div>

        </div>

        <p class="text-center text-zinc-600 mt-8 text-sm max-w-2xl mx-auto">
          Aujourd'hui, je mets cette double expertise au service des animaux, de leurs propriétaires et des entreprises qui œuvrent pour leur santé.
        </p>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="py-28 text-center max-w-4xl mx-auto px-6 bg-zinc-50">
      <h2 class="text-4xl font-light">
        Travaillons ensemble
      </h2>

      <p class="mt-4 text-zinc-600">
        Chaque situation est unique. Je vous propose un premier échange afin de comprendre votre besoin et construire un accompagnement adapté.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact"
           class="px-6 py-3 text-white rounded-full colors-cta">
          Me contacter
        </a>

        <a href="tel:+33XXXXXXXXX"
           class="px-6 py-3 border border-zinc-300 rounded-full hover:border-zinc-900 transition">
          Appeler
        </a>
      </div>
    </section>

</BaseLayout>
